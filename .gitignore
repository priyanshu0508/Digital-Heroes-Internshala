# =============================================================
# Digital Heroes — .gitignore
# =============================================================

# ---- Dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js Build Output ----
/.next/
/out/
/build

# ---- Environment Variables (NEVER COMMIT API KEYS) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*

# ---- Vercel ----
.vercel

# ---- Supabase ----
/supabase/.temp/
/supabase/.branches/

# ---- Stripe CLI (local binary) ----
stripe.exe
stripe

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Testing & Coverage ----
/coverage
/playwright-report
/test-results

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS Files ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Editor & IDE ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Misc ----
*.pem
*.key
*.cert
